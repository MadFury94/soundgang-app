{
    "name": "soundgang-api",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "db:migrate": "wrangler d1 execute soundgang-db --remote --file=./migrations/001_schema.sql",
        "db:seed": "wrangler d1 execute soundgang-db --remote --file=./migrations/002_seed.sql",
        "db:migrate:local": "wrangler d1 execute soundgang-db --local --file=./migrations/001_schema.sql",
        "db:seed:local": "wrangler d1 execute soundgang-db --local --file=./migrations/002_seed.sql",
        "db:migrate:003": "wrangler d1 execute soundgang-db --remote --file=./migrations/003_users_and_fk.sql",
        "db:migrate:003:local": "wrangler d1 execute soundgang-db --local --file=./migrations/003_users_and_fk.sql",
        "db:seed:admin": "wrangler d1 execute soundgang-db --remote --file=./migrations/004_seed_admin.sql",
        "db:seed:admin:local": "wrangler d1 execute soundgang-db --local --file=./migrations/004_seed_admin.sql",
        "test": "vitest run"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20241224.0",
        "fast-check": "^4.7.0",
        "typescript": "^5.0.0",
        "vitest": "^4.1.5",
        "wrangler": "^3.0.0"
    },
    "dependencies": {
        "@types/bcryptjs": "^2.4.6",
        "bcryptjs": "^3.0.3",
        "jose": "^6.2.2"
    }
}