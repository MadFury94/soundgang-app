{
    "name": "soundgang-api",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "db:migrate": "wrangler d1 execute soundgang-db --file=./migrations/001_schema.sql",
        "db:seed": "wrangler d1 execute soundgang-db --file=./migrations/002_seed.sql",
        "db:migrate:local": "wrangler d1 execute soundgang-db --local --file=./migrations/001_schema.sql",
        "db:seed:local": "wrangler d1 execute soundgang-db --local --file=./migrations/002_seed.sql"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20241224.0",
        "typescript": "^5.0.0",
        "wrangler": "^3.0.0"
    }
}